# Required: GitHub Personal Access Token
PAT_1=ghp_your_token_here

# Optional: add more tokens for better resilience
# PAT_2=ghp_your_second_token_here
# PAT_3=ghp_your_third_token_here

# Optional runtime settings
PORT=9000
CACHE_SECONDS=21600

# Optional security/privacy controls
# WHITELIST=your_github_username
# GIST_WHITELIST=abcdef1234567890
# EXCLUDE_REPO=private-repo-1,private-repo-2
